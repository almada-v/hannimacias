---
interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        
        <!-- Tus iconos -->
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
        
        <!-- SEO y Meta Tags -->
        <title>{title}</title>
        <meta name="description" content="Servicios profesionales de cosmetología en Cihuatlán. Cuidado facial y tratamientos especializados." />
        
        <!-- Open Graph -->
        <meta property="og:title" content={title} />
        <meta property="og:description" content="Tratamientos faciales y cuidado de la piel de alta calidad en Cihuatlán." />
        <meta property="og:url" content="https://www.hmcosmetologa.com/" />
        <meta property="og:type" content="website" />
    </head>
    <body class="bg-stone-50 text-stone-800 min-h-screen font-sans antialiased">
        <slot />
    </body>
</html>

<style>
    html, body { margin: 0; width: 100%; height: 100%; }
</style>