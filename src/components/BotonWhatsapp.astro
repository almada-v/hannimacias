---
// src/components/BotonWhatsapp.astro

const telefono = "523151204677"; 
const mensaje = encodeURIComponent("¡Hola! Vi tu página web y me gustaría pedir informes sobre los paquetes de faciales.");

// Aquí construimos el enlace con las comillas invertidas correctas
const linkWhatsapp = `https://wa.me/${telefono}?text=${mensaje}`;
---

<!-- CORRECCIÓN EN EL HREF: En Astro, las variables dinámicas van sin comillas dobles alrededor de las llaves -->
<a 
  href={linkWhatsapp}
  id="whatsapp-flotante"
  class="fixed bottom-6 right-6 z-50 flex items-center justify-center bg-[#25D366] text-white w-14 h-14 rounded-full shadow-[0_8px_24px_rgba(37,211,102,0.3)] transition-all duration-300 active:scale-90 active:brightness-95 touch-manipulation [webkit-tap-highlight-color:transparent]"
  aria-label="Contactar por WhatsApp"
>
  <svg class="w-8 h-8 fill-current" viewBox="0 0 24 24" xmlns="http://w3.org">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.455 5.703 1.455h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
</a>

<script>
  const floatBtn = document.getElementById('whatsapp-flotante');
  
  if (floatBtn) {
    floatBtn.addEventListener('click', () => {
      if (navigator.vibrate) navigator.vibrate(40);
    });

        setInterval(() => {
      // CORRECCIÓN TOTAL: Casteamos 'window' completo como 'any' antes de buscar la propiedad
      const win = window as any;
      
      if (typeof window !== 'undefined' && win.estadoCarritoGlobal) {
        const estadoCarrito = win.estadoCarritoGlobal;
        
        if (estadoCarrito.totalProductos > 0) {
          if (estadoCarrito.resumenAbierto) {
            floatBtn.style.transform = 'translateY(-345px)';
          } else {
            floatBtn.style.transform = 'translateY(-85px)';
          }
        } else {
          floatBtn.style.transform = 'translateY(0px)';
        }
      } else {
        floatBtn.style.transform = 'translateY(0px)';
      }
    }, 100); 

  }
</script>
