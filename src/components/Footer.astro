---
// src/components/Footer.astro
import { Image } from 'astro:assets';
import logoEmpresa from '../assets/logo.svg'; 

const telefono = "523151195149"; 
const mensajeTexto = "¡Hola! Me gustaría pedir más información.";
const linkWhatsApp = `https://wa.me/${telefono}?text=${encodeURIComponent(mensajeTexto)}`;
const linkInstagram = "https://instagram.com/almadavidrio/";

const añoActual = new Date().getFullYear();
---

<footer class="bg-[#ffffff] border-t border-[#737373]/10 py-12 md:py-16 select-none">
  <div class="max-w-6xl mx-auto px-6">
    
    <!-- GRID PRINCIPAL: 1 columna en móvil, 3 en pantallas grandes/tabletas -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8 pb-12 border-b border-[#737373]/5 text-center md:text-left">
      
            <!-- Columna 1: Identidad Boutique Cosmética (Logotipo Expandido y Texto Justificado) -->
      <div class="space-y-5 text-left flex flex-col items-center md:items-start">
        
        <!-- Enlace del Logo: Altura incrementada progresivamente para máxima legibilidad en cualquier pantalla -->
        <a href="/" class="inline-block h-12 md:h-14 w-auto [webkit-tap-highlight-color:transparent]" aria-label="Volver al inicio">
          <Image 
            src={logoEmpresa} 
            alt="Logo Cosmetóloga" 
            class="h-full w-auto object-contain object-center md:object-left" 
            width={240} 
            height={56}
          /> 
        </a>
        
        <!-- Párrafo Descriptivo: Justificado de borde a borde para un aspecto de diseño de nivel editorial de lujo -->
        <p class="text-[#737373] text-xs sm:text-sm leading-relaxed max-w-sm font-light text-justify">
          Elevamos el cuidado de tu piel a un nivel de experiencia premium con tratamientos personalizados y tecnología clínica de vanguardia.
        </p>
        
      </div>


      <!-- Columna 2: Enlaces de Navegación Rápidos -->
      <div class="space-y-4">
        <h3 class="text-[10px] font-bold tracking-widest text-[#737373]/60 uppercase">Explorar</h3>
        <nav class="flex flex-col space-y-3 text-xs font-semibold text-[#737373] uppercase tracking-wider">
          <a href="/" class="hover:text-[#4d2819] transition-colors [webkit-tap-highlight-color:transparent]">Inicio</a>
          <a href="#servicios" class="hover:text-[#4d2819] transition-colors [webkit-tap-highlight-color:transparent]">Tratamientos</a>
          <a href="#galeria" class="hover:text-[#4d2819] transition-colors [webkit-tap-highlight-color:transparent]">Nosotros</a>
          <a href="#ubicacion" class="hover:text-[#4d2819] transition-colors [webkit-tap-highlight-color:transparent]">Ubicación</a>
          <a href="#faq" class="hover:text-[#4d2819] transition-colors [webkit-tap-highlight-color:transparent]">¿Dudas?</a>
        </nav>
      </div>

      <!-- Columna 3: Canales de Contacto Directo Táctil -->
      <div class="space-y-4">
        <h3 class="text-[10px] font-bold tracking-widest text-[#737373]/60 uppercase">Contacto Directo</h3>
        <div class="flex flex-col items-center md:items-start space-y-3 text-xs text-[#737373] font-light">
          <p class="font-medium text-[#000000]">📞 +52 315 119 5149</p>
          <p class="font-medium text-[#000000]">✉️ hola@tuclinicaejemplo.com</p>
          
          <!-- Botones de Redes Sociales con micro-vibración y vectores corregidos -->
          <div class="flex items-center gap-4 pt-2">
            <!-- Instagram -->
            <a 
              href={linkInstagram} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="btn-footer-social w-10 h-10 rounded-xl bg-[#737373]/5 text-[#000000] flex items-center justify-center transition-all duration-75 [webkit-tap-highlight-color:transparent]"
              aria-label="Seguir en Instagram"
            >
              <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" xmlns="http://w3.org">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </a>
            
            <!-- WhatsApp -->
            <a 
              href={linkWhatsApp} 
              target="_blank"
              rel="noopener noreferrer"
              class="btn-footer-social w-10 h-10 rounded-xl bg-[#737373]/5 text-[#000000] flex items-center justify-center transition-all duration-75 [webkit-tap-highlight-color:transparent]"
              aria-label="Escribir por WhatsApp"
            >
              <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" xmlns="http://w3.org">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.455 5.703 1.455h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- SECCIÓN INFERIOR: Derechos de autor y créditos -->
    <div class="pt-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-[11px] text-[#737373]/60 font-light tracking-wide text-center">
      <p>© {añoActual} Todos los derechos reservados.</p>
      <p class="font-semibold uppercase tracking-[0.15em] text-[#737373]/40">
        Diseño por <span class="text-[#4d2819] font-bold">almadavidrio</span>
      </p>
    </div>

  </div>
</footer>
<script>
  // Inicialización rápida de eventos de hardware
  document.addEventListener("pointerdown", function() {}, {passive: true});

  const botonesSociales = document.querySelectorAll('.btn-footer-social');

  // Control elástico para los iconos de redes sociales (Compatibilidad unificada PC/Celulares)
  botonesSociales.forEach(boton => {
    boton.addEventListener('pointerdown', (e) => {
      if (navigator.vibrate) {
        navigator.vibrate(25);
      }
      const target = e.currentTarget as HTMLElement;
      target.classList.add('scale-[0.90]', 'bg-[#737373]/15');
    });

    ['pointerup', 'pointerleave'].forEach(evt => {
      boton.addEventListener(evt, (e) => {
        const target = e.currentTarget as HTMLElement;
        setTimeout(() => {
          target.classList.remove('scale-[0.90]', 'bg-[#737373]/15');
        }, 100);
      });
    });
  });
</script>
