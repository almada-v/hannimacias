---
import { Image } from 'astro:assets';
import fondoImagen from '../assets/FONDO1.webp';

const telefono = "523151204677";
const mensajeTexto = "¡Hola! Me gustaría agendar una cita.";
const linkWhatsApp = `https://wa.me/${telefono}?text=${encodeURIComponent(mensajeTexto)}`;
---

<!-- Estructura fluida y suave para Cosmetología -->
<section class="relative w-full min-h-[95svh] lg:min-h-[90svh] flex flex-col lg:flex-row bg-[#ffffff] overflow-hidden select-none">
  
  <!-- CONTENEDOR DE IMAGEN: Curvatura orgánica en base que simula la fluidez de una crema o sérum -->
  <div class="relative w-full h-[48svh] lg:h-auto lg:w-[50%] lg:order-2 shrink-0 z-10 overflow-hidden bg-neutral-100">
    <Image 
      src={fondoImagen} 
      alt="Cosmetología facial y salud de la piel" 
      class="w-full h-full object-cover object-center scale-100" 
      quality="high" 
      format="webp" 
      width={1200}
      height={900}
      widths={[390, 768, 1200, 1600]}
      sizes="(max-width: 640px) 390px, (max-width: 1024px) 768px, 1200px"
      loading="eager"
      fetchpriority="high"
    />
    
    <!-- Degradados de fusión cosmética: Eliminan cortes drásticos y suavizan la imagen en móviles -->
    <div class="absolute inset-0 bg-gradient-to-t from-[#ffffff] via-[#ffffff]/30 to-transparent lg:bg-gradient-to-r lg:from-[#ffffff] lg:via-[#ffffff]/10 lg:to-transparent z-20"></div>
    
    <!-- Onda fluida estética exclusiva para móviles que aporta la identidad de cosmetología -->
    <div class="absolute bottom-0 left-0 right-0 h-8 bg-[#ffffff] z-20 block lg:hidden" style="clip-path: ellipse(60% 100% at 50% 100%);"></div>
  </div>

  <!-- CONTENEDOR DE TEXTO: Cálido, limpio y enfocado en el bienestar de la piel -->
  <div class="relative flex-1 flex flex-col justify-center px-6 py-6 lg:py-12 lg:px-20 z-30 lg:order-1 items-center lg:items-start text-center lg:text-left bg-[#ffffff]">
    <div class="animate-enter-up space-y-6 max-w-md lg:max-w-xl mx-auto lg:mx-0">
      
      <!-- Subtítulo en Gris Mineral suave -->
      <span class="inline-block text-[10px] font-sans font-semibold tracking-[0.25em] uppercase text-[#737373]">
        DALE A TU PIEL EL BRILLO QUE MERECE
      </span>
      
      <!-- Título: Delicado, usando Marrón Profundo para evocar extractos naturales y aceites esenciales -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif text-[#000000] leading-[1.15] tracking-tight">
        Sana tu piel <br />
        <span class="italic font-normal text-[#4d2819]">desde el interior.</span>
      </h1>
      
      <!-- Párrafo descriptivo enfocado en la salud dérmica -->
      <p class="text-[#737373] text-sm sm:text-base leading-relaxed max-w-xs sm:max-w-sm lg:max-w-md mx-auto lg:mx-0">
        Tratamientos personalizados que respetan y restauran la barrera cutánea de tu rostro. Devuelve la luminosidad y vitalidad natural a tu piel.
      </p>
      
      <!-- BOTÓN DE CONVERSIÓN TÁCTIL (Corregido para ejecución inmediata de eventos) -->
      <div class="pt-2 w-full flex justify-center lg:justify-start">
        <a 
          href={linkWhatsApp} 
          id="btn-cosmetologa" 
          target="_blank"
          rel="noopener noreferrer"
          class="relative inline-block w-full max-w-[310px] touch-manipulation [webkit-tap-highlight-color:transparent]"
          aria-label="Agendar cita de cosmetología por WhatsApp"
        >
          <!-- Botón principal con bordes muy redondeados (suavidad cosmética) -->
          <span id="btn-visual-target" class="flex items-center justify-center bg-[#4d2819] text-base text-[#ffffff] font-medium rounded-full py-4 w-full transition-all duration-150 shadow-lg shadow-[#4d2819]/15 border border-[#4d2819]">
            ¡ Quiero una cita !
          </span>
          
          <!-- Destellos sutiles biológicos -->
          <div class="absolute inset-0 pointer-events-none text-[#4d2819]/20">
            <div class="absolute z-10 animate-subtle-sparkle" style="top: -10%; left: 90%;"><svg viewBox="0 0 68 68" height="10" width="10"><path fill="currentColor" d="M26.5 25.5C19.0043 33.3697 0 34 0 34C0 34 19.1013 35.3684 26.5 43.5C33.234 50.901 34 68 34 68C34 68 36.9884 50.7065 44.5 43.5C51.6431 36.647 68 34 68 34C68 34 51.6947 32.0939 44.5 25.5C36.5605 18.2235 34 0 34 0C34 0 33.6591 17.9837 26.5 25.5Z"></path></svg></div>
          </div>
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  // Habilitar de forma global que iOS responda al toque (:active) de CSS de inmediato
  document.addEventListener("touchstart", function() {}, {passive: true});

  const btn = document.getElementById('btn-cosmetologa');
  const targetVisual = document.getElementById('btn-visual-target');

  if (btn && targetVisual) {
    // CAPTURA DE INTERACCIÓN MÓVIL INMEDIATA
    btn.addEventListener('touchstart', () => {
      // 1. Solución de Vibración: Ahora con milisegundos asignados (Sólo Android por restricción de Apple)
      if (navigator.vibrate) {
        navigator.vibrate(30); 
      }
      
      // 2. Solución Visual Universal (iOS y Android): Cambio drástico e instantáneo al tocar
      targetVisual.classList.remove('bg-[#4d2819]', 'text-[#ffffff]');
      targetVisual.classList.add('bg-[#ffffff]', 'text-[#000000]', 'scale-[0.96]');
    }, { passive: true });

    // RESTAURACIÓN VISUAL AL LEVANTAR EL DEDO
    btn.addEventListener('touchend', () => {
      setTimeout(() => {
        targetVisual.classList.remove('bg-[#ffffff]', 'text-[#000000]', 'scale-[0.96]');
        targetVisual.classList.add('bg-[#4d2819]', 'text-[#ffffff]');
      }, 100); // Pequeño retraso para que el ojo humano note el destello táctil
    });
  }
</script>

<style>
  /* Animación orgánica de entrada */
  @keyframes enterUp {
    0% { opacity: 0; transform: translateY(10px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .animate-enter-up {
    animation: enterUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* Brillo parpadeante muy suave que emula la luz reflejada en la piel sana */
  @keyframes subtleSparkle {
    0%, 100% { opacity: 0; transform: scale(0.5); }
    50% { opacity: 0.7; transform: scale(1.1); }
  }
  .animate-subtle-sparkle {
    animation: subtleSparkle 5s infinite ease-in-out;
  }
</style>
