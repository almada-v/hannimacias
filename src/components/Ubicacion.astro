---
// src/components/Ubicacion.astro
import { Image } from 'astro:assets';
import mapaCaptura from '../assets/mapa.png'; 

const direccionFormateada = "Av. Principal 123, Colonia Centro, Ciudad de Ejemplo";
const googleMapsLink = "https://maps.app.goo.gl/xRudpSxEaEM1oy4V8";
const appleMapsLink = `https://maps.apple/p/W.N~d~9-SXcUh-`;
---

<section id="ubicacion" class="py-20 lg:py-28 bg-[#ffffff] select-none">
  <div class="max-w-6xl mx-auto px-6">
    
    <!-- CONTENEDOR MAESTRO: Distribución limpia a dos columnas paralelas en pantallas grandes -->
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-12 lg:gap-16">
      
      <!-- COLUMNA IZQUIERDA: Bloque Editorial de Información -->
      <div class="w-full lg:w-[45%] flex flex-col justify-center space-y-10">
        
        <!-- Encabezado Clínico Sofisticado -->
        <div class="space-y-3 text-left">
          <span class="inline-block text-[10px] font-bold tracking-[0.35em] uppercase text-[#737373]">
            Nuestra Ubicación
          </span>
          <h2 class="text-4xl md:text-5xl font-serif font-normal text-[#000000] leading-[1.1] tracking-tight">
            Un oasis clínico <br />
            <span class="italic font-normal text-[#4d2819]">diseñado para tu piel.</span>
          </h2>
        </div>

        <!-- Línea Divisoria Premium de 1px -->
        <div class="w-full h-[1px] bg-[#737373]/10"></div>

        <!-- Detalles de Contacto Resumidos con Tipografía Limpia -->
        <div class="space-y-8 text-left">
          <!-- Dirección Física -->
          <div class="space-y-1">
            <h3 class="text-[10px] font-bold tracking-wider text-[#737373]/60 uppercase font-sans">Dirección de la Cabina</h3>
            <p class="text-[#000000] text-base font-light leading-relaxed max-w-sm">{direccionFormateada}</p>
          </div>

          <!-- Horarios Detallados -->
          <div class="space-y-3">
            <h3 class="text-[10px] font-bold tracking-wider text-[#737373]/60 uppercase font-sans">Horarios Clínicos</h3>
            <div class="max-w-xs space-y-2 text-sm text-[#737373] font-light">
              <div class="flex justify-between border-b border-[#737373]/5 pb-1.5">
                <span class="text-[#000000] font-medium">Lunes a Viernes</span>
                <span>9:00 AM — 7:00 PM</span>
              </div>
              <div class="flex justify-between border-b border-[#737373]/5 pb-1.5">
                <span class="text-[#000000] font-medium">Sábados</span>
                <span>9:00 AM — 2:00 PM</span>
              </div>
              <div class="flex justify-between text-[#737373]/40">
                <span>Domingos</span>
                <span class="font-light">Cerrado</span>
              </div>
            </div>
          </div>
        </div>

        <!-- BOTONERA SELECTORA INTEGRADA: Botón exclusivo para usuarias de iPhone -->
        <div class="pt-2">
          <a 
            href={appleMapsLink}
            class="btn-gps btn-apple inline-flex items-center justify-center gap-2.5 py-4 px-8 w-full sm:w-auto bg-[#4d2819] text-[#ffffff] text-[10px] font-bold uppercase tracking-widest rounded-full transition-all duration-150 shadow-lg shadow-[#4d2819]/10 touch-manipulation [webkit-tap-highlight-color:transparent]"
          >
            <span>Navegar con Apple Maps</span>
          </a>
        </div>
      </div>

      <!-- COLUMNA DERECHA: Contenedor del Mapa Visual de Lujo -->
      <div class="w-full lg:w-[50%] flex flex-col space-y-4">
        
        <!-- Marco Flotante Estilizado con Esquinas Suaves -->
        <div class="relative w-full h-72 sm:h-96 lg:h-[460px] bg-neutral-50 rounded-[2.5rem] overflow-hidden border border-[#737373]/10 shadow-[0_12px_40px_rgba(0,0,0,0.02)]">
          <Image 
            src={mapaCaptura} 
            alt="Mapa de nuestra ubicación exacta" 
            class="w-full h-full object-cover brightness-[0.98] contrast-[1.01]"
            width={600}
            height={460}
            widths={[400, 600]}
            sizes="(max-width: 1024px) 100vw, 600px"
            loading="lazy"
          />
          <!-- Máscara de fusión de bordes premium -->
          <div class="absolute inset-0 ring-1 ring-inset ring-black/5 rounded-[2.5rem] pointer-events-none"></div>
        </div>

        <!-- Enlace Secundario para Google Maps (Ubicado elegantemente abajo del mapa) -->
        <div class="text-center lg:text-left pl-2">
          <a 
            href={googleMapsLink}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-gps text-[11px] font-semibold tracking-wider text-[#4d2819] uppercase hover:text-[#000000] transition-colors duration-200 inline-flex items-center gap-1.5 [webkit-tap-highlight-color:transparent]"
          >
            <span>Alternativa: Abrir en Google Maps</span>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
        </div>
        
      </div>

    </div>
  </div>
</section>
<script>
  // Asegura la respuesta táctil unificada e instantánea
  document.addEventListener("pointerdown", function() {}, {passive: true});

  const enlacesGps = document.querySelectorAll('.btn-gps');

  enlacesGps.forEach(enlace => {
    enlace.addEventListener('pointerdown', (e) => {
      if (navigator.vibrate) navigator.vibrate(35);

      const target = e.currentTarget as HTMLElement;
      
      // Animación elástica exclusiva para el botón principal de Apple Maps
      if (target.classList.contains('btn-apple')) {
        target.classList.remove('bg-[#4d2819]');
        target.classList.add('bg-[#000000]', 'scale-[0.96]');
      }
    });

    ['pointerup', 'pointerleave'].forEach(evt => {
      enlace.addEventListener(evt, (e) => {
        const target = e.currentTarget as HTMLElement;
        setTimeout(() => {
          if (target.classList.contains('btn-apple')) {
            target.classList.remove('bg-[#000000]', 'scale-[0.96]');
            target.classList.add('bg-[#4d2819]');
          }
        }, 120);
      });
    });
  });
</script>
