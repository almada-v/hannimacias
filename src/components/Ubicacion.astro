---
const direccionFormateada = "Aquiles Serdán #58, Centro, Cihuatlán, Jalisco";
const googleMapsLink = "https://maps.app.goo.gl/c6t8bZbwESyVb8HX8";
const appleMapsLink = "https://apple.com";

// MÁSTERS DE CONFIGURACIÓN: Enlace de inserción real de Google Maps.
const googleMapsEmbedUrl = "https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d684.7052543742354!2d-104.56177306305871!3d19.237173817824274!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zMTnCsDE0JzE0LjEiTiAxMDTCsDMzJzQyLjEiVw!5e0!3m2!1ses!2smx!4v1781730563457!5m2!1ses!2smx";
---

<section id="ubicacion" class="py-20 lg:py-28 bg-[#ffffff] select-none overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">
    
    <!-- CONTENEDOR MAESTRO -->
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-center">
      
      <!-- COLUMNA IZQUIERDA: Bloque de Información Completamente Centrado en Móvil e iPad -->
      <div class="w-full lg:w-[45%] flex flex-col justify-center py-2 text-center lg:text-left">
        
        <div class="space-y-10">
          <!-- Encabezado Clínico Sofisticado -->
          <div class="space-y-3">
            <span class="inline-block text-[10px] font-bold tracking-[0.35em] uppercase text-[#737373]">
              Nuestra Ubicación
            </span>
            <h2 class="text-4xl md:text-5xl font-serif font-normal text-[#000000] leading-[1.1] tracking-tight">
              Un oasis clínico <br />
              <span class="italic font-normal text-[#4d2819]">diseñado para tu piel.</span>
            </h2>
          </div>

          <!-- Detalles de Contacto -->
          <div class="space-y-8 flex flex-col items-center lg:items-start">
            <!-- Dirección Física -->
            <div class="space-y-2 w-full">
              <h3 class="text-[10px] font-bold tracking-wider text-[#737373]/60 uppercase font-sans">Dirección de la Cabina</h3>
              <p class="text-[#000000] text-base font-light leading-relaxed max-w-sm mx-auto lg:mx-0">{direccionFormateada}</p>
            </div>

            <!-- Horarios Detallados -->
            <div class="space-y-3 w-full flex flex-col items-center lg:items-start">
              <h3 class="text-[10px] font-bold tracking-wider text-[#737373]/60 uppercase font-sans">Horarios</h3>
              <div class="w-full max-w-xs space-y-2 text-sm text-[#737373] font-light">
                <div class="flex justify-between border-b border-[#737373]/5 pb-1.5">
                  <span class="text-[#000000] font-medium">Lunes a Sábado</span>
                  <span>9:00 AM — 8:00 PM</span>
                </div>
                <div class="flex justify-between text-[#737373]/40">
                  <span>Domingos</span>
                  <span class="font-light">Cerrado</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- BOTÓN INTELIGENTE CENTRADO -->
        <div class="pt-10 flex justify-center lg:justify-start">
          <a 
            id="btn-gps-inteligente"
            href={googleMapsLink}
            target="_blank"
            rel="noopener noreferrer"
            data-apple={appleMapsLink}
            data-google={googleMapsLink}
            class="w-full sm:w-auto inline-flex items-center justify-center gap-3 py-4 px-8 bg-[#4d2819] text-[#ffffff] text-[10px] font-bold uppercase tracking-widest rounded-full transition-all duration-150 shadow-lg shadow-[#4d2819]/10 touch-manipulation [webkit-tap-highlight-color:transparent]"
          >
            <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24" xmlns="http://w3.org">
              <path d="M12 0C7.582 0 4 3.582 4 8c0 5.25 8 16 8 16s8-10.75 8-16c0-4.418-3.582-8-8-8zm0 11c-1.657 0-3-1.343-3-3s1.343-3 3-3 3 1.343 3 3-1.343 3-3 3z"/>
            </svg>
            <span id="texto-gps-inteligente">Abrir en Google Maps</span>
          </a>
        </div>
      </div>

      <!-- COLUMNA DERECHA: Espacio del Mapa Real e Interactivo -->
      <div class="w-full lg:w-[55%] flex flex-col min-h-[380px] lg:min-h-[460px]">
        <div class="relative w-full h-full min-h-[380px] sm:min-h-[440px] lg:min-h-[460px] bg-neutral-50 rounded-[2.5rem] overflow-hidden border border-[#737373]/10 shadow-[0_12px_40px_rgba(0,0,0,0.01)]">
          
          <iframe 
            src={googleMapsEmbedUrl}
            class="w-full h-full min-h-[380px] sm:min-h-[440px] lg:min-h-[460px] border-0"
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
            title="Mapa en vivo de nuestra ubicación"
          ></iframe>
          
          <div class="absolute inset-0 ring-1 ring-inset ring-black/5 rounded-[2.5rem] pointer-events-none"></div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const btnGps = document.getElementById('btn-gps-inteligente') as HTMLAnchorElement | null;
    const txtGps = document.getElementById('texto-gps-inteligente');

    if (!btnGps || !txtGps) return;

    const esApple = /iPhone|iPad|iPod|Macintosh/i.test(navigator.userAgent);

    if (esApple) {
      const urlApple = btnGps.getAttribute('data-apple');
      if (urlApple) {
        btnGps.href = urlApple;
        btnGps.removeAttribute('target');
        txtGps.innerText = "Navegar con Apple Maps";
      }
    }

    btnGps.addEventListener('pointerdown', () => {
      if (navigator.vibrate) navigator.vibrate(35);
      btnGps.classList.remove('bg-[#4d2819]');
      btnGps.classList.add('bg-[#000000]', 'scale-[0.97]');
    });

    ['pointerup', 'pointerleave'].forEach(evt => {
      btnGps.addEventListener(evt, () => {
        setTimeout(() => {
          btnGps.classList.remove('bg-[#000000]', 'scale-[0.97]');
          btnGps.classList.add('bg-[#4d2819]');
        }, 120);
      });
    });
  });
</script>
