---
// src/components/Navbar.astro
import { Image } from 'astro:assets';
import logoEmpresa from '../assets/logo.svg'; 

const telefono = "523151204677"; 
const mensajeTexto = "¡Hola! Me gustaría agendar una cita";
const linkWhatsApp = `https://wa.me/${telefono}?text=${encodeURIComponent(mensajeTexto)}`;
---

<!-- HEADER PRINCIPAL -->
<header id="navbar" class="fixed top-0 left-0 w-full z-50 h-20 bg-white/70 backdrop-blur-md transition-all duration-300 ease-in-out select-none border-b border-[#737373]/5">
  <div class="max-w-6xl mx-auto px-6 h-full flex items-center justify-between">
    
      <!-- Busca el contenedor del logo en la parte superior de tu Navbar.astro y reemplaza la etiqueta por esta: -->
      <a href="/" class="flex items-center h-full [webkit-tap-highlight-color:transparent]" aria-label="Volver al inicio">
        <Image 
          src={logoEmpresa} 
          alt="Logo de la empresa" 
          class="h-10 w-auto lg:h-12 object-contain transition-all duration-300" 
          width={220} 
          height={52}
          loading="eager"
          fetchpriority="high"
        /> 
      </a>


    <!-- CORRECCIÓN 1: Menú de Escritorio (Cambiado de 'hidden md:flex' a 'hidden lg:flex' para proteger el iPad) -->
    <nav class="hidden lg:flex items-center space-x-8 lg:space-x-10 text-[10px] font-semibold tracking-[0.3em] text-[#737373] uppercase">
      <a href="/" class="hover:text-[#4d2819] transition-all duration-300">Inicio</a>
      <a href="#servicios" class="hover:text-[#4d2819] transition-all duration-300">Tratamientos</a>
      <a href="#galeria" class="hover:text-[#4d2819] transition-all duration-300">Nosotros</a>
      <a href="#ubicacion" class="hover:text-[#4d2819] transition-all duration-300">Ubicación</a>
      <a href="#faq" class="hover:text-[#4d2819] transition-all duration-300">¿Dudas?</a>
    </nav>

    <!-- Área de Conversión Rápida + Hamburguesa -->
    <div class="flex items-center gap-4">
      <a 
        href={linkWhatsApp} 
        id="btn-nav-whatsapp"
        target="_blank"
        rel="noopener noreferrer"
        class="px-5 py-2.5 text-[10px] font-bold tracking-[0.2em] uppercase border border-[#4d2819]/20 text-[#4d2819] rounded-full bg-white/90 backdrop-blur-sm transition-all duration-150 touch-manipulation [webkit-tap-highlight-color:transparent]"
      >
        Agendar Cita
      </a>

      <!-- CORRECCIÓN 2: Icono Hamburguesa (Cambiado de 'md:hidden' a 'lg:hidden' para que esté activo en tablets) -->
      <button 
        id="menu-toggle"
        class="flex flex-col justify-center items-center w-11 h-11 gap-1.5 lg:hidden text-[#000000] focus:outline-none touch-manipulation [webkit-tap-highlight-color:transparent]"
        aria-label="Abrir menú de navegación"
      >
        <span class="w-5 h-0.5 bg-current rounded-full transition-all duration-300 linea-1"></span>
        <span class="w-5 h-0.5 bg-current rounded-full transition-all duration-300 linea-2"></span>
      </button>
    </div>
  </div>
</header>

<!-- MENÚ MÓVIL PANTALLA COMPLETA (Cambiado 'md:hidden' a 'lg:hidden' al final) -->
<div 
  id="mobile-menu" 
  class="fixed inset-0 bg-[#ffffff]/98 backdrop-blur-2xl z-[40] flex flex-col justify-center items-center transition-all duration-300 ease-in-out opacity-0 pointer-events-none -translate-y-4 lg:hidden"
>
  <nav class="flex flex-col items-center space-y-8 text-xs font-bold tracking-[0.4em] text-[#737373] uppercase">
    <a href="/" class="link-movil text-[#000000] transition-colors">Inicio</a>
    <a href="#servicios" class="link-movil transition-colors">Tratamientos</a>
    <a href="#galeria" class="link-movil transition-colors">Nosotros</a>
    <a href="#ubicacion" class="link-movil transition-colors">Ubicación</a>
    <a href="#faq" class="link-movil transition-colors">¿Dudas?</a>
  </nav>
</div>

<script>
  // Habilitar la escucha activa e inmediata en dispositivos iOS y Android
  document.addEventListener("pointerdown", function() {}, {passive: true});

  const navbar = document.getElementById('navbar');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const linksMovil = document.querySelectorAll('.link-movil');
  const btnNavWhatsapp = document.getElementById('btn-nav-whatsapp');

  // 1. CONTROL DE SCROLL: Cambio estético fluido al bajar la pantalla
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar?.classList.replace('h-20', 'h-14');
      navbar?.classList.replace('bg-white/70', 'bg-white/95');
      navbar?.classList.add('shadow-[0_4px_30px_rgba(0,0,0,0.02)]', 'border-b-[#737373]/10');
    } else {
      navbar?.classList.replace('h-14', 'h-20');
      navbar?.classList.replace('bg-white/95', 'bg-white/70');
      navbar?.classList.remove('shadow-[0_4px_30px_rgba(0,0,0,0.02)]', 'border-b-[#737373]/10');
    }
  }, { passive: true });

  // 2. CONTROL DEL MENÚ MÓVIL CON RETROALIMENTACIÓN UNIVERSAL
  const toggleMenu = () => {
    if (navigator.vibrate) navigator.vibrate(25); 

    const isOpen = mobileMenu?.classList.contains('opacity-100');

    if (isOpen) {
      mobileMenu?.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
      mobileMenu?.classList.add('opacity-0', 'pointer-events-none', '-translate-y-4');
      menuToggle?.classList.remove('menu-abierto');
    } else {
      mobileMenu?.classList.remove('opacity-0', 'pointer-events-none', '-translate-y-4');
      mobileMenu?.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
      menuToggle?.classList.add('menu-abierto');
    }
  };

  // Escucha de alta velocidad mediante pointerdown (unifica clics de PC y toques de celular)
  menuToggle?.addEventListener('pointerdown', (e) => {
    e.preventDefault(); 
    toggleMenu();
  });
  
  linksMovil.forEach(link => {
    link.addEventListener('pointerdown', () => {
      toggleMenu();
    });
  });

  // 3. RESPUESTA TÁCTIL VISUAL E HÁPTICA PARA EL BOTÓN DE WHATSAPP DE LA NAVBAR
  if (btnNavWhatsapp) {
    btnNavWhatsapp.addEventListener('pointerdown', () => {
      if (navigator.vibrate) navigator.vibrate(35);
      
      btnNavWhatsapp.classList.remove('text-[#4d2819]', 'bg-white/90');
      btnNavWhatsapp.classList.add('text-[#ffffff]', 'bg-[#4d2819]', 'scale-[0.96]');
    });

    ['pointerup', 'pointerleave'].forEach(evt => {
      btnNavWhatsapp.addEventListener(evt, () => {
        setTimeout(() => {
          btnNavWhatsapp.classList.remove('text-[#ffffff]', 'bg-[#4d2819]', 'scale-[0.96]');
          btnNavWhatsapp.classList.add('text-[#4d2819]', 'bg-white/90');
        }, 100);
      });
    });
  }
</script>

<style>
  /* Transformación milimétrica de la hamburguesa cosmética a una cruz fluida */
  .menu-abierto .linea-1 {
    transform: translateY(4px) rotate(45deg);
  }
  .menu-abierto .linea-2 {
    transform: translateY(-4px) rotate(-45deg);
  }
</style>
